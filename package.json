{
  "name": "fastify-monorepo",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint:ci": "oxlint && oxfmt --check",
    "lint": "oxlint --fix && oxfmt --write",
    "setup-commit-hooks": "pnpm husky",
    "pre-commit": "pnpm lint-staged",
    "generate:package": "turbo gen workspace --copy @repo/templates-package --type package",
    "generate:api": "turbo gen workspace --copy @repo/templates-api --type api",
    "generate:temporal-app": "turbo gen temporal-app",
    "temporal:up": "docker compose -f tooling/temporal-dev-server/docker-compose.yml up -d",
    "temporal:down": "docker compose -f tooling/temporal-dev-server/docker-compose.yml down",
    "turbo": "turbo"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:tooling",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "catalog:tooling",
    "oxlint": "catalog:tooling",
    "oxlint-tsgolint": "catalog:tooling",
    "turbo": "^2.8.17",
    "vitest": "catalog:testing"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
