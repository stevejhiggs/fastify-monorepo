{
  "name": "example-api",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/listener.js",
  "scripts": {
    "dev": "node --import tsx --watch-path=./src ./src/index.ts | pino-pretty ",
    "dev:with-telemetry": "node --import tsx  --import ./src/telemetry.ts --watch-path=./src ./src/index.ts | pino-pretty ",
    "debug": "node --inspect --import tsx ./src/index.ts ",
    "start:production": "node --enable-source-maps ./.dist/index.mjs",
    "build": "tsdown",
    "test": "LOG_LEVEL=warn vitest",
    "test:ci": "LOG_LEVEL=warn vitest --coverage",
    "typecheck": "tsgo --noEmit",
    "lint:ci": "oxlint --type-aware --type-check ./src && oxfmt --check ./src",
    "lint": "oxlint --type-aware --type-check --fix ./src && oxfmt --write ./src"
  },
  "dependencies": {
    "@repo/fastify-base": "workspace:*",
    "fastify": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest": "workspace:*",
    "@types/node": "catalog:tooling",
    "@typescript/native-preview": "catalog:tooling",
    "@vitest/coverage-v8": "catalog:testing",
    "globals": "^17.0.0",
    "oxfmt": "catalog:tooling",
    "oxlint": "catalog:tooling",
    "oxlint-tsgolint": "catalog:tooling",
    "pino-pretty": "^13.1.3",
    "tsdown": "catalog:tooling",
    "tsx": "catalog:tooling",
    "vitest": "catalog:testing"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "oxlint --type-aware --type-check --fix",
      "oxfmt --write"
    ]
  }
}
