{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "import", "node", "promise", "unicorn", "typescript", "oxc"],
  "env": {
    "node": true,
    "es2024": true
  },
  "rules": {
    "unicorn/prefer-for-of": "error",
    "unicorn/filename-case": ["error", { "case": "kebabCase" }]
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "ignorePatterns": ["**/node_modules", "**/.dist", "**/.turbo", "**/coverage"]
}
