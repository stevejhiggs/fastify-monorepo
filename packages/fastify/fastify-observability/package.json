{
  "name": "@repo/fastify-observability",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./logging": "./src/logging.ts",
    "./open-telemetry": "./src/open-telemetry/index.ts",
    "./open-telemetry/setup": "./src/open-telemetry/setup.ts"
  },
  "scripts": {
    "lint:ci": "oxlint --type-aware --type-check ./src && oxfmt --check ./src",
    "lint": "oxlint --type-aware --type-check --fix ./src && oxfmt --write ./src",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@fastify/otel": "^0.16.0",
    "@fastify/request-context": "^6.2.1",
    "@repo/logging": "workspace:*",
    "@repo/open-telemetry": "workspace:*"
  },
  "peerDependencies": {
    "fastify": "^5"
  },
  "devDependencies": {
    "oxlint": "catalog:tooling",
    "oxlint-tsgolint": "catalog:tooling",
    "oxfmt": "catalog:tooling",
    "@repo/fastify-common-types": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:tooling",
    "@typescript/native-preview": "catalog:tooling"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "oxlint --type-aware --type-check --fix",
      "oxfmt --write"
    ]
  }
}
