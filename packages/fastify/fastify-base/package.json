{
  "name": "@repo/fastify-base",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./caching": "./src/caching.ts",
    "./logging": "./src/logging.ts",
    "./multipart": "./src/multipart.ts",
    "./telemetry/setup": "./src/telemetry/setup.ts"
  },
  "scripts": {
    "lint:ci": "oxlint --type-aware --type-check ./src && oxfmt --check ./src",
    "lint": "oxlint --type-aware --type-check --fix ./src && oxfmt --write ./src",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@repo/caching": "workspace:*",
    "@repo/fastify-multipart": "workspace:*",
    "@repo/fastify-observability": "workspace:*",
    "@repo/fastify-security": "workspace:*",
    "@repo/fastify-swagger": "workspace:*",
    "@repo/fastify-zod": "workspace:*",
    "@repo/logging": "workspace:*"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:tooling",
    "@typescript/native-preview": "catalog:tooling",
    "oxfmt": "catalog:tooling",
    "oxlint": "catalog:tooling",
    "oxlint-tsgolint": "catalog:tooling"
  },
  "peerDependencies": {
    "fastify": "catalog:"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "oxlint --type-aware --type-check --fix",
      "oxfmt --write"
    ]
  }
}
