{
  "name": "@repo/open-telemetry",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint:ci": "oxlint --type-aware ./src && oxfmt --check ./src",
    "lint": "oxlint --type-aware --fix ./src && oxfmt --write ./src",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.2",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.208.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/instrumentation-http": "^0.208.0",
    "@opentelemetry/instrumentation-undici": "^0.19.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@repo/typescript-utils": "workspace:*"
  },
  "devDependencies": {
    "oxlint": "catalog:tooling",
    "oxlint-tsgolint": "catalog:tooling",
    "oxfmt": "catalog:tooling",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:tooling",
    "@typescript/native-preview": "catalog:tooling"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "oxlint --type-aware --fix",
      "oxfmt --write"
    ]
  }
}
