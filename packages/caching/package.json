{
  "name": "@repo/caching",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint:ci": "oxlint --type-aware ./src && oxfmt --check ./src",
    "lint": "oxlint --type-aware --fix ./src && oxfmt --write ./src",
    "typecheck": "tsgo --noEmit",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.4",
    "cacheable": "^2.3.0",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "oxlint": "catalog:tooling",
    "oxlint-tsgolint": "catalog:tooling",
    "oxfmt": "catalog:tooling",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest": "workspace:*",
    "@types/node": "catalog:tooling",
    "@vitest/coverage-v8": "catalog:testing",
    "@typescript/native-preview": "catalog:tooling",
    "vitest": "catalog:testing"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "oxlint --type-aware --fix",
      "oxfmt --write"
    ]
  }
}
