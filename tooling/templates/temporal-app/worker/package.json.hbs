{
  "name": "@repo/{{name}}-worker",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "node --import tsx --watch-path=./src ./src/index.ts | pino-pretty",
    "start:production": "node --enable-source-maps ./.dist/index.mjs",
    "build": "tsdown"
  },
  "dependencies": {
    "@repo/{{name}}-workflows": "workspace:*",
    "@repo/logging": "workspace:*",
    "@repo/temporal": "workspace:*",
    "@temporalio/worker": "catalog:temporal",
    "@temporalio/workflow": "catalog:temporal"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:tooling",
    "pino-pretty": "catalog:tooling",
    "tsdown": "catalog:tooling",
    "tsx": "catalog:tooling"
  }
}
